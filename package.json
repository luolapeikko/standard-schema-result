{
	"$schema": "https://www.schemastore.org/package.json",
	"name": "@luolapeikko/standard-schema-result",
	"version": "0.0.2",
	"description": "Rust style result type for standard schema validation",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		"import": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"require": {
			"types": "./dist/index.d.cts",
			"default": "./dist/index.cjs"
		},
		"default": "./dist/index.mjs"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"prepare": "lefthook install",
		"build": "tsdown src/index.ts --format cjs,esm --dts --clean",
		"prepublishOnly": "npm run build",
		"test": "vitest test --run --no-isolate --coverage",
		"lint": "biome check",
		"validate": "tsgo --noEmit --project tsconfig.test.json"
	},
	"repository": "github:luolapeikko/standard-schema-result",
	"keywords": [
		"zod",
		"valibot",
		"arktype",
		"result",
		"rust",
		"validation",
		"standard-schema"
	],
	"author": "mharj",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@luolapeikko/result-option": "^2.3.0",
		"@standard-schema/spec": "^1.1.0",
		"@standard-schema/utils": "^0.3.0",
		"@tsconfig/node24": "^24.0.4",
		"@types/express": "^5.0.6",
		"@types/express-serve-static-core": "^5.1.1",
		"@types/node": "^25.9.4",
		"@typescript/native-preview": "7.0.0-dev.20260704.1",
		"@vitest/coverage-v8": "^4.1.9",
		"c8": "^11.0.0",
		"express": "^5.2.1",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.9",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@luolapeikko/result-option": ">= 2.0.0",
		"@standard-schema/spec": ">= 1.1.0",
		"@standard-schema/utils": ">= 0.3.0"
	},
	"packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d"
}
